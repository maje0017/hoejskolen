</p>
</div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-screen-xl mx-auto px-4 py-8">
  <!-- Left column: 2 stacked cards -->
  <div class="flex flex-col space-y-6">
    <Card2
