---
import MainLayout from "../layouts/MainLayout.astro";
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Card2  from '../components/Card2.astro';
import Card3  from '../components/Card3.astro';
import Link from '../components/Link.astro';
import { Image } from 'astro:assets';
import thumbsup from "../assets/images/thumbsup.png";
---
<MainLayout title="Titel">
	 <!--Start på hero unit sektion -->
<section class="relative h-screen w-full overflow-hidden">
  <!-- Full-cover Image -->
  <img src="hero.png" 
       alt="Hero" 
       class="absolute inset-0 w-full h-full object-cover z-0" />

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/30 z-10"></div>

  <!-- Text container with adjusted mobile position -->
  <div class="relative z-20 w-full h-full text-orange-50 font-serif font-normal flex flex-col justify-center items-start px-6 sm:px-12 pb-70">
    <!-- HØJSKOLE (Responsive position) -->
    <h1 class="text-6xl sm:text-6xl md:text-8xl xl:text-8xl leading-tight 
               sm:text-left md:text-left xl:text-left sm:mt-12 md:mt-25 xl:mt-10">
      HØJSKOLE
    </h1>

    <!-- I UDLANDET (Responsive position) -->
    <h1 class="text-6xl sm:text-6xl md:text-8xl xl:text-8xl leading-tight 
               sm:text-left md:text-left xl:text-left sm:mt-4 md:mt-8 xl:mt-4">
      I UDLANDET
    </h1>
  </div>
</section>
	 <!--Slut på hero unit sektion -->

   <!--Start på card  sektion -->
   <section class="pt-20">
    <div class="flex justify-center items-center space-x-4">
        <h1 class="text-3xl sm:text-xl md:text-6xl text-center text-orange-900 font-serif font-normal pb-6 sm:pb-8">
          VÆLG DIN
        </h1>
        <h1 class="text-3xl sm:text-xl md:text-6xl text-center text-orange-500 font-serif font-normal pb-6 sm:pb-8">
          DESTINATION
        </h1>
    </div>
       <div class="max-w-screen-xl mx-auto px-9">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-12 pt-8">
      <Card
        url="/singleview"
        cardimage="20230326_224852_37C325.webp"
        cardimagealt="Trip 1"
        cardtitel="Maldiverne, Sri Lanka, Bali, Gili Island, Japan & Australien"
        cardtekst="Varighed:"
        cardtekst2="3 måneder"
        cardtekst3="Pris:"
        cardtekst4="89.900.-"
        cardbuttontekst="Læs mere! →"
        badgenyt="false"
        badgerabat="false"
        badgefaatilbage="false"
      ></Card>

      <Card
        url="/singleview"
        cardimage="20221217_232124_5AA72F.webp"
        cardimagealt="Trip 2"
        cardtitel="Australien, New Zealand, Vietnam, Bali, Gili Island & Lombok"
        cardtekst="Varighed:"
        cardtekst2="4 måneder"
        cardtekst3="Pris:"
        cardtekst4="74.900.-"
        cardbuttontekst="Læs mere! →"
        badgenyt="false"
        badgerabat="false"
        badgefaatilbage="false"
      ></Card>

      <Card
        url="/singleview"
        cardimage="20221210_161841_146567.webp"
        cardimagealt="Trip 3"
        cardtitel="Australien, New Zealand, Vietnam, Bali, Gili Island & Lombok"
        cardtekst="Varighed:"
        cardtekst2="5 måneder"
        cardtekst3="Pris:"
        cardtekst4="146.000.-"
        cardbuttontekst="Læs mere! →"
        badgenyt="false"
        badgerabat="false"
        badgefaatilbage="false"
      ></Card>
     
      </div>
     <!-- Aligned Button -->
    <div class="flex justify-center mt-5 pr-5">
      <button class="bg-orange-900 hover:bg-orange-500 text-orange-50 p-3 rounded-xl font-normal font-serif">
        Se alle rejser →
      </button>
       </div>
   </section>
    <!--Slut på card sektion -->

   <!--Start på billede sektion -->
     <section class="pt-20 px-4">
  <h1 class="text-3xl sm:text-4xl md:text-5xl text-center font-serif font-normal pb-6 sm:pb-8">
  ER DU KLAR TIL DIT LIVS EVENTYR?
</h1>

<h3 class="text-base sm:text-lg md:text-xl font-serif font-normal leading-relaxed max-w-3xl mx-auto  px-4">
  HÖJSKOLENDK er en dansk højskole for unge i alderen ca. 18-30 år.<br>
  Vi brænder for oplevelser, fællesskab og mødet med nye mennesker og kulturer.<br>
  Derfor laver vi eventyrlige højskoleophold i udlandet.
</h3>


<!-- Container wrapper to unify layout -->
<div class="max-w-screen-lg mx-auto px-4">

  <!-- Image row -->
  <div class="flex justify-center pt-10 overflow-x-auto">
    <div class="flex flex-row space-x-6">
      <div>
        <img src="20230416_035311_9BB228.webp"
          class="rounded-xl sm:rounded-2xl md:rounded-4xl w-40 sm:w-52 md:w-64 h-auto sm:h-72 md:h-90 object-cover" />
      </div>
      <div>
        <img src="20230423_125316_49FEB8.webp"
          class="rounded-xl sm:rounded-2xl md:rounded-4xl w-40 sm:w-52 md:w-64 h-auto sm:h-72 md:h-90 object-cover" />
      </div>
      <div>
        <img src="20230720_064137_2F1B53.webp"
          class="rounded-xl sm:rounded-2xl md:rounded-4xl w-40 sm:w-52 md:w-64 h-auto sm:h-72 md:h-90 object-cover" />
      </div>
      <div>
        <img src="20230403_020825_28D846.webp"
          class="rounded-xl sm:rounded-2xl md:rounded-4xl w-40 sm:w-52 md:w-64 h-auto sm:h-72 md:h-90 object-cover" />
      </div>
    </div>
  </div>

  <!-- Text & Button Row -->
  <div class="flex flex-col md:flex-row justify-between items-center gap-8 py-10">
    <!-- Left Text -->
    <div class="md:w-1/2">
      <h3 class="text-base md:text-lg font-serif leading-relaxed">
        HÖJSKOLENDK er noget for dig, hvis du vil på højskole i udlandet og er vild med højskolefællesskab, vil med på et
        fantastisk rejseeventyr, glæder dig til at lære om fremmede kulturer, vil rejse med rygsæk, drømmer om en fed
        grupperejse med andre skønne unge, vil opleve et stærkt sammenhold og ønsker inspirerende og meningsfuld
        undervisning. <br> Du er sikker på en tryg rejseoplevelse da vi er medlem af Rejsegarantifonden.
      </h3>
    </div>

   <!-- Right Side -->
<div class="md:w-1/2 flex flex-col md:items-end text-center md:text-right space-y-4 pb-45">
  <h3 class="text-base md:text-lg font-serif">
    Vi glæder os til at lære dig at kende!
  </h3>
  <button class="bg-orange-900 hover:bg-orange-500 text-orange-50 text-xl p-3 rounded-xl self-center md:self-end font-normal font-serif">
    Vælg dit eventyr 
  </button>
</div>

  </div>

</div>
</section>
    <!--Slut på billede sektion -->

     <!--Start på info sektion -->
       <section class="pt-20 px-4">
        <h1 class="text-4xl sm:text-xl md:text-8xl text-center text-orange-500 font-serif font-normal pb-6 sm:pb-8">
          Höjskolendk
        </h1>

<div class="max-w-screen-xl mx-auto px-4 pt-10">
  <div class="flex flex-col md:flex-row justify-between items-stretch gap-8 min-h-[500px]">
    
    <!-- Left Side: Text -->
    <div class="md:w-2/3 h-full">
      <div class="h-full flex flex-col justify-between">
        <h3 class="text-xl md:text-2xl font-serif font-bold leading-relaxed h-full">
          REJSE HØJSKOLE
        </h3>
        <p class="text-lg md:text-base font-serif leading-relaxed h-full">
          Der venter dig et unikt rejseeventyr når du tager på højskole i udlandet, med et stærkt sammenhold og fede rejseoplevelser. Med udgangspunkt i højskolens to grundværdier fællesskab og dannelse, kan du på højskole i udlandet bruge din sabbatår rejse på fx frivilligt arbejde, vilde adventure- og naturoplevelser, lære sprog og spændende personlig udvikling der giver dig mere selvtillid, selvindsigt og selvværd. Glæd dig også til inspirerende undervisning, der levende og aktivt forener det lærende med det legende.
          <br><br>
          Vores elever beskriver HÖJSKOLENDK som ”eventyrlige dannelsesrejser med noget på hjerte”. Udover det fantastiske rejseeventyr handler vores højskoleophold i udlandet om dine drømme, mål og ønsker for livet. På inspirerende og aktiv vis flytter du dine grænser og bliver en endnu stærkere udgave af dig selv. Vi tror på, at du kommer hjem med mere mod på alt hvad livet byder dig og er mere afklaret omkring hvad en meningsfuld fremtid er for dig.
          <br><br>
          Tag på højskole i udlandet hvis du har du lyst til at opleve verden, udleve dine rejsedrømme i et skønt fællesskab, blive inspireret af dygtige og engagerede undervisere og få et eventyr for livet.
        </p>
      </div>
    </div>

    <!-- Right Side: Image -->
    <div class="md:w-1/3 h-full">
      <img
        src="20221217_232124_5AA72F.webp"
        alt="Højskolendk Rejse"
        class="rounded-4xl w-full h-full object-cover"
      />
    </div>

  </div>
</div>

<div class="max-w-screen-xl mx-auto px-4 pt-10">
  <div class="flex flex-col md:flex-row justify-between items-stretch gap-8 min-h-[500px]">
    
    <!-- Left Side: Image (1/3) -->
    <div class="md:w-1/3 h-full">
      <img
        src="20230512_131621_2339EA.webp"
        alt="Højskolendk Rejse"
        class="rounded-4xl w-full h-110 object-cover"
      />
    </div>

    <!-- Right Side: Text (2/3) -->
    <div class="md:w-2/3 h-full">
      <div class="h-full flex flex-col justify-between">
        <h3 class="text-xl md:text-2xl font-serif font-bold leading-relaxed">
          HØJSKOLEOPHOLD I UDLANDET
        </h3>
        <p class="text-lg md:text-base font-serif leading-relaxed mt-4">
         Når du rejser på højskole i udlandet med HÖJSKOLENDK…
         <br>
         › bliver du en del af et fantastisk fællesskab med et stærkt sammenhold
         <br> 
         › får du masser af vilde naturoplevelser, adventure og spændende kulturmøder
         <br>
         › opdager du nye og stærke sider af dig selv, flytter grænser og får mere selvtillid
         <br>
         › rejser du altid med danske passionerede rejseledere og engagerede undervisere
         <br>
         › får du et uforglemmeligt, unikt og trygt rejseeventyr for livet
        <br><br>
         Med vores unikke kombination af højskole, grupperejser, rejseeventyr, frihed, kulturmøder og spændende undervisning, vil vi inspirere dig til at finde ind til hvad der er vigtigst for dig i livet – hvad du virkeligt brænder for og kan mærke er meningsfuldt – så du kan forfølge dine drømme.
        <br><br>
        Gå på opdagelse her på siden efter dit livs eventyr – på højskole i udlandet med HÖJSKOLENDK.
        <br><br>
        Velkommen!
        </p>
      </div>
    </div>

  </div>
</div>
